#!/bin/sh
# OpenDN CUPS backend — the virtual printer's back end. CUPS hands every job
# printed to an OpenDN queue to this script as a PDF; it lands in the watch
# folder named in the queue's device URI (opendn:/path/to/input), where
# `opendn watch` picks it up and stamps it.
#
# Installed 0700 root:root so CUPS runs it as root (the cups-pdf trick):
# that lets it write into the user's watch folder and chown the file to the
# user who printed. Never run this by hand as root outside of CUPS.
#
# CUPS calls it as:  opendn job-id user title copies options [file]
# and with no arguments for backend discovery.

if [ $# -eq 0 ]; then
    echo 'file opendn:/ "OpenDN" "OpenDN delivery-note capture (folder)"'
    exit 0
fi

if [ $# -lt 5 ] || [ $# -gt 6 ]; then
    echo "ERROR: opendn backend: expected 5 or 6 arguments, got $#" >&2
    exit 1
fi

case "$DEVICE_URI" in
    opendn:*) ;;
    *) echo "ERROR: opendn backend: DEVICE_URI must be opendn:/abs/path (got: $DEVICE_URI)" >&2; exit 1 ;;
esac
DEST=$(printf '%s' "${DEVICE_URI#opendn:}" | sed 's|^/*|/|')
if [ "$DEST" = "/" ]; then
    echo "ERROR: opendn backend: no capture folder in device URI" >&2
    exit 1
fi

JOB_USER=$2
TITLE=$(printf '%s' "$3" | tr -cs 'A-Za-z0-9._-' '_' | cut -c1-80)
[ -n "$TITLE" ] || TITLE=job

mkdir -p "$DEST" || { echo "ERROR: opendn backend: cannot create $DEST" >&2; exit 1; }

# no timestamp here — the watcher adds date+time to every output name;
# the -N loop alone keeps simultaneous same-title captures apart
OUT="$DEST/$TITLE.pdf"
N=1
while [ -e "$OUT" ]; do
    OUT="$DEST/$TITLE-$N.pdf"
    N=$((N + 1))
done

# write to a .part name first so the watcher only ever sees complete PDFs
TMP="$OUT.part"
if [ $# -eq 6 ]; then
    cat "$6" > "$TMP" || { rm -f "$TMP"; echo "ERROR: opendn backend: write failed" >&2; exit 1; }
else
    cat > "$TMP" || { rm -f "$TMP"; echo "ERROR: opendn backend: write failed" >&2; exit 1; }
fi
chown "$JOB_USER" "$TMP" 2>/dev/null || true
chmod 644 "$TMP"
mv "$TMP" "$OUT"

echo "INFO: OpenDN captured job to $OUT" >&2
exit 0
